{
  "name": "parallax",
  "version": "0.1.0",
  "description": "Local-first code impact analysis for agentic coding workflows.",
  "license": "MIT",
  "author": "YouSangSon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YouSangSon/Parallax.git"
  },
  "bugs": {
    "url": "https://github.com/YouSangSon/Parallax/issues"
  },
  "homepage": "https://github.com/YouSangSon/Parallax#readme",
  "keywords": [
    "agentic-coding",
    "code-analysis",
    "impact-analysis",
    "mcp",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "parallax": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "bench": "tsx bench/impact-bench.ts",
    "bench:report": "tsx bench/impact-bench-report.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:fixtures": "npm test",
    "test:security": "tsx --test tests/security.test.ts",
    "test:mcp": "tsx --test tests/mcp.test.ts",
    "test:ui": "tsx --test tests/ui.test.ts",
    "test:dogfood": "tsx --test tests/dogfood.integration.ts",
    "test:benchmark": "npm run bench",
    "test:install-smoke": "npm run build && node dist/src/cli.js --help",
    "docs:lint": "node scripts/docs-lint.js",
    "lint": "npm run check && npm run docs:lint",
    "verify": "npm run lint && npm run test:install-smoke && npm test && npm run test:dogfood && npm run bench && npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist/src",
    "README.md",
    "docs"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sqlite-vec": "^0.1.9",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
